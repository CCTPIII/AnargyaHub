local Section = Tab:CreateSection("Auto Fuse Pets")

local AutoFuse = false

local Toggle = Tab:CreateToggle({
   Name = "Auto Fuse",
   CurrentValue = false,
   Flag = "AutoFuse",

   Callback = function(Value)

      AutoFuse = Value

      if Value then
         task.spawn(function()

            local Player = game.Players.LocalPlayer

            local RemoteFunction = game:GetService("ReplicatedStorage")
                :WaitForChild("Msg")
                :WaitForChild("RemoteFunction")

            while AutoFuse do

                local DidFuse = false

                local ScrollPet = Player.PlayerGui
                    .ScreenGui
                    .Pet
                    .Frame
                    .ScrollPet

                for _, pet in pairs(ScrollPet:GetChildren()) do

                    if not AutoFuse then
                        break
                    end

                    if tonumber(pet.Name) and pet:FindFirstChild("Button") then

                        for _, c in pairs(getconnections(pet.Button.MouseButton1Click)) do
                            c:Fire()
                        end

                        task.wait(0.5)

                        local txt = Player.PlayerGui
                            .ScreenGui
                            .Pet
                            .Frame
                            .PetDetails
                            .Buttons["合成"]
                            .Frame
                            .FuseCount.Text

                        local current = tonumber(txt:match("(%d+)/"))

                        if current and current >= 3 then

                            RemoteFunction:InvokeServer(
                                "FusePet",
                                tonumber(pet.Name)
                            )

                            DidFuse = true

                            task.wait(1)

                            break
                        end
                    end
                end

                if not DidFuse then
                    task.wait(3)
                end

            end

         end)
      end

   end,
})
