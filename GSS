local AutoCycleTrain = false

Tab:CreateToggle({
   Name = "Auto Cycle Train",
   CurrentValue = false,
   Flag = "AutoCycleTrain",

   Callback = function(Value)
      AutoCycleTrain = Value
   end,
})

task.spawn(function()
    local RemoteEvent = game:GetService("ReplicatedStorage")
        :WaitForChild("Msg")
        :WaitForChild("RemoteEvent")

    local Setting = game:GetService("ReplicatedStorage")
        :WaitForChild("ServerMsg")
        :WaitForChild("Setting")

    local Machines = {
        "\230\137\139\232\135\1301", -- Arms
        "\229\141\167\230\142\1682", -- Chest
        "\230\139\137\229\138\155\229\153\1683", -- Back
        "\232\133\185\233\131\168\229\141\183\232\133\1854", -- Abs
        "\232\133\191\233\131\168\229\153\168\230\162\1763", -- Leg
        "\232\128\144\229\138\1556", -- Stamina
    }

    while true do
        if AutoCycleTrain then
            for _, machine in ipairs(Machines) do
                if not AutoCycleTrain then
                    break
                end

                pcall(function()
                    RemoteEvent:FireServer(
                        "StartTrain",
                        workspace:WaitForChild("Scene")
                            :WaitForChild("1")
                            :WaitForChild("Training equipment")
                            :WaitForChild(machine)
                    )
                end)

                task.wait(0.3)

                pcall(function()
                    Setting:InvokeServer("isAutoClick", 1)
                end)

                local elapsed = 0
                while elapsed < 20 and AutoCycleTrain do
                    task.wait(0.1)
                    elapsed = elapsed + 0.1
                end
            end
        else
            task.wait(0.1)
        end
    end
end)


